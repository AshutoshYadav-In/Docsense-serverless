{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ServerlessCloudFormation",
      "Effect": "Allow",
      "Action": "cloudformation:*",
      "Resource": "*"
    },
    {
      "Sid": "ServerlessIAMRoles",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:PassRole",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRolePolicy",
        "iam:ListRolePolicies",
        "iam:UpdateAssumeRolePolicy",
        "iam:TagRole",
        "iam:UntagRole"
      ],
      "Resource": "*"
    },
    {
      "Sid": "LambdaStepFunctionsLogsS3",
      "Effect": "Allow",
      "Action": [
        "lambda:*",
        "states:*",
        "logs:*",
        "apigateway:*",
        "events:*",
        "s3:*",
        "ssm:GetParameter",
        "ssm:GetParameters",
        "kms:Decrypt",
        "kms:DescribeKey"
      ],
      "Resource": "*"
    }
  ]
}
