# Copy to ".env" (gitignored) and fill real values, then:
#   npm run deploy
#   npm run package
# (both load .env via dotenv-cli — see package.json "scripts")
#
# Required when deploying (serverless.yml):
#   AWS_REGION
#   JAVA_API_BASE_URL — embedChunk + bulkInsertAndComplete Lambdas only
#
# S3 bucket for PDFs is not in .env — pass `bucket` in the Step Functions execution input.
#
# Optional (documentation only):
#   AWS_ACCOUNT_ID
#
# Client id/token: SSM at runtime — /x-client-id, /x-client-token (see functions/utils/clientCredentials.js)

AWS_REGION=ap-south-1
JAVA_API_BASE_URL=https://your-java-api.example.com

# AWS_ACCOUNT_ID=123456789012
